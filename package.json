{
  "name": "obsidian-local-rest-api",
  "version": "4.1.0",
  "description": "A secure REST API and Model Context Protocol (MCP) server for Obsidian.",
  "main": "main.js",
  "types": "main.d.ts",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "node --max-old-space-size=6144 node_modules/.bin/tsc -noEmit -skipLibCheck",
    "build-docs": "jsonnet -J docs/src/lib/ -S docs/src/openapi.jsonnet -o docs/openapi.yaml",
    "serve-docs": "npx serve docs",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src/",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/glob-to-regexp": "^0.4.1",
    "@types/jest": "^29",
    "@types/mime-types": "^2.1.1",
    "@types/node": "^18",
    "@types/node-forge": "^1.0.0",
    "@types/supertest": "^2.0.11",
    "@types/uuid": "^8.3.4",
    "esbuild": "0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "jest": "^29",
    "obsidian": "latest",
    "supertest": "^6.2.2",
    "ts-jest": "^29",
    "tslib": "2.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "zod": "3.25.76"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.24.3",
    "@types/response-time": "^2.3.5",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "glob-to-regexp": "^0.4.1",
    "json-logic-js": "^2.0.2",
    "markdown-patch": "^1.0.0",
    "matcher": "^5.0.0",
    "mime-types": "^2.1.35",
    "minimatch": "^5.0.1",
    "node-forge": "^1.2.1",
    "obsidian-daily-notes-interface": "^0.9.4",
    "obsidian-dataview": "^0.5.47",
    "query-string": "^7.1.1",
    "response-time": "^2.3.2",
    "uuid": "^8.3.2"
  }
}
